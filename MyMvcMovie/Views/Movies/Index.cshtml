@* @model IEnumerable<MyMvcMovie.Models.Movie> *@
@model PaginatedList<Movie>

@{
    ViewData["Title"] = "Index";
}

<h1>Movies</h1>

<div class="header">
    <div style="display:flex; width: 100%; margin: 20px;">
        <form asp-controller="Movies" asp-action="Index" method="get" style="width: 100%;">
            <div class="form-actions" style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                <a asp-action="Create" class="btn btn-primary custom-purple-button">Create new movie</a>
                <div style="display: flex; align-items: center; gap: 10px; flex-grow: 1; justify-content: center;">
                    <label style="margin: 0; white-space: nowrap;">
                        Find by name🔎:
                        <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" />
                        <button type="submit" class="btn btn-primary custom-green-button">Search</button>
                    </label>
                </div>
                    <a asp-action="Index" class="btn btn-primary custom-purple-button">Back to the whole list</a>
            </div>
        </form>
    </div>
</div>
<div class="table-responsive-fixed-width">
    <table class="table create-new-link">
        <thead>
            <tr>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewData["TitleSort"]"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]">
                        @Html.DisplayNameFor(model => model.First().Title)
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewData["DateSort"]"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]">
                        @Html.DisplayNameFor(model => model.First().ReleaseDate)
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewData["GenreSort"]"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]">
                        @Html.DisplayNameFor(model => model.First().Genre)
                    </a>
                </th>
                @*        <th>
                @Html.DisplayNameFor(model => model.URL)
                </th>
                <th>
                @Html.DisplayNameFor(model => model.Brief)
                </th>
                <th>
                @Html.DisplayNameFor(model => model.Poster)
                </th> *@
                @*   <th>
                @Html.DisplayNameFor(model => model.photo)
                </th> *@
             @*    <th>
                    @Html.DisplayNameFor(model => model.First().Price)
                </th> *@
                @*      <th>
                @Html.DisplayNameFor(model => model.Rating)
                </th> *@
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Title)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReleaseDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Genre)
                </td>
                @*  <td>
                @Html.DisplayFor(modelItem => item.URL)
                </td>
                <td>
                @Html.DisplayFor(modelItem => item.Brief)
                </td>
                <td>
                @Html.DisplayFor(modelItem => item.Poster)
                </td> *@
                @*    <th>
                @Html.DisplayNameFor(model => model.photo)
                </th> *@
              @*   <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td> *@
                @*             <th>
                @Html.DisplayNameFor(model => model.Rating)
                </th> *@
                    <td class="actions-cell" style="white-space: nowrap;">
                    <a asp-action="Edit" class="btn btn-primary edit custom-blue-button" asp-route-id="@item.Id">Edit</a> 
                    <a asp-action="Details" class="btn btn-primary custom-blue-button" asp-route-id="@item.Id">Details</a> 
@*                     <a asp-action="Delete" class="btn btn-primary edit custom-purple-button" asp-route-id="@item.Id">Delete</a> *@
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

@{
    string prevDisabled = Model.HasPrevPage ? "" : "disabled";
    string nextDisabled = Model.HasNextPage ? "" : "disabled";
}

<div style="display:flex;justify-content:center;">
    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-primary custom-green-button @prevDisabled">
        Prev
    </a>
    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-primary custom-green-button @nextDisabled">
        Next
    </a>
</div>