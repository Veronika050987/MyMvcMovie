@model IEnumerable<MyMvcMovie.Models.Movie>

@{
    ViewData["Title"] = "Index";
}
<style>
    /*styles for the same column width during pagination and filtration*/
    .table-responsive-fixed-width {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

        .table-responsive-fixed-width .table {
            width: 100%;
            table-layout: fixed;
            border-collapse: collapse;
        }

            .table-responsive-fixed-width .table th,
            .table-responsive-fixed-width .table td {
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

                .table-responsive-fixed-width .table th:nth-child(1),
                .table-responsive-fixed-width .table td:nth-child(1) {
                    width: 50%;
                }

                .table-responsive-fixed-width .table th:nth-child(2),
                .table-responsive-fixed-width .table td:nth-child(2) {
                    width: 30%;
                }

            .table-responsive-fixed-width .table a {
                display: inline-block;
                width: 100%;
                text-overflow: ellipsis;
                overflow: hidden;
                white-space: nowrap;
            }
    /*for links colors*/
    p .create-new-link {
        color: purple;
    }

        p .create-new-link:hover {
            color: darkorchid;
        }
    table .create-new-link {
        color: purple;
    }

        table .create-new-link:hover {
            color: darkorchid;
        }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        color: #4B0082;
    }

    h2 {
        color: #7B68EE;
    }
    p {
        text-align: center;
    }

    th {
        color: #4169E1;
    }
    /*to have a distance between Prev/Next and 3-5-8-10*/
    .form-group-margin-top {
        margin-top: 20px;
    }
    /*Edit, details, delete*/
    .actions-cell {
        display: flex;
        justify-content: space-around;
        align-items: center;
    }

    .action-link {
        display: inline-block;
        flex: 1 1 auto;
        text-align: center;
        text-decoration: none;
    }

    /* Если нужно, чтобы кнопки были примерно одинаковой ширины */
    .action-link {
        flex: 1; /* Каждый элемент займет равную долю */
        text-align: center;
    }
    /*for buttons colors*/
    .custom-purple-button.btn-primary {
        background-color: #8A2BE2;
        border-color: #4B0082;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1),
                    0 2px 4px rgba(0, 0, 0, 0.08);
        color: white;
    }

        .custom-purple-button.btn-primary:hover {
            background-color: #BA55D3;
            border-color: darkorchid;
            box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15),
                        0 3px 6px rgba(0, 0, 0, 0.12);
        }

    .custom-purple-button.disabled {
        background-color: #D3D3D3;
        border-color: #D3D3D3;
        color: #6c757d;
    }

</style>
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-controller="Movies" asp-action="Index" method="get">
    <p>
        <input type="text" name="SearchString" />
        <input type="submit" value="Find" />
    </p>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReleaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genre)
            </th>
     @*        <th>
                @Html.DisplayNameFor(model => model.URL)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Brief)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poster)
            </th> *@
          @*   <th>
                @Html.DisplayNameFor(model => model.photo)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
       @*      <th>
                @Html.DisplayNameFor(model => model.Rating)
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Genre)
            </td>
           @*  <td>
                @Html.DisplayFor(modelItem => item.URL)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Brief)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Poster)
            </td> *@
         @*    <th>
               @Html.DisplayNameFor(model => model.photo)
            </th> *@
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
@*             <th>
                @Html.DisplayNameFor(model => model.Rating)
            </th> *@
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
