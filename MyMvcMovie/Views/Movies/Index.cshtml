@model IEnumerable<MyMvcMovie.Models.Movie>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div class="header">
    <div style="display:flex;">
        <div style="margin: 0px 20px;">
            <a asp-action="Create" class="btn btn-primary custom-purple-button">Create new movie</a>
        </div>
    </div>

    @* <p>
    <a asp-action="Create">Create New</a>
    </p> *@
    <form asp-controller="Movies" asp-action="Index" method="get">
        <div class="form-actions no-color">
            <p>
                Find by name🔎:
                <input type="text" name="SearchString" />
                <input type="submit" value="Find" />
                @*         <a asp-action="Index">Back to List</a> *@
                <a asp-action="Index" class="btn btn-primary custom-purple-button">Back to List</a>
            </p>
        </div>
    </form>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["TitleSort"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]">
                    @Html.DisplayNameFor(model => model.Title)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["DateSort"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]">
                    @Html.DisplayNameFor(model => model.ReleaseDate)
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["GenreSort"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]">
                    @Html.DisplayNameFor(model => model.Genre)
                </a>
            </th>
     @*        <th>
                @Html.DisplayNameFor(model => model.URL)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Brief)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Poster)
            </th> *@
          @*   <th>
                @Html.DisplayNameFor(model => model.photo)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
       @*      <th>
                @Html.DisplayNameFor(model => model.Rating)
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Genre)
            </td>
           @*  <td>
                @Html.DisplayFor(modelItem => item.URL)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Brief)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Poster)
            </td> *@
         @*    <th>
               @Html.DisplayNameFor(model => model.photo)
            </th> *@
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
@*             <th>
                @Html.DisplayNameFor(model => model.Rating)
            </th> *@
            <td>
                    <a asp-action="Edit" class="btn btn-primary edit custom-purple-button" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" class="btn btn-primary custom-purple-button" asp-route-id="@item.Id">Details</a>
                    @*             <a asp-action="Delete" asp-route-id="@item.Id">Delete</a> *@
            </td>
        </tr>
}
    </tbody>
</table>
